# Example config generated/used by bootstrap/start.sh
PROXMOX_HOST="10.10.10.10"
PROXMOX_NODE="pve-deploy"
PROXMOX_API_ENDPOINT="https://10.10.10.10:8006/api2/json"
RALF_DOMAIN="otta.zone"
RALF_DNS_MODE="internal-zone"
RALF_DNS_ZONE="otta.zone"
RALF_DNS_RESOLVER="10.10.0.1"
# Optional DNS target platform metadata
# RALF_DNS_PLATFORM="opnsense-unbound"
# RALF_DNS_OPNSENSE_HOST="10.10.0.1"
RALF_NETWORK_CIDR="10.10.0.0/16"
RALF_GATEWAY="10.10.0.1"
RALF_BRIDGE="vmbr0"
RALF_STORAGE="local-lvm"
RALF_TEMPLATE_STORAGE="local"
RALF_TEMPLATE_NAME="ubuntu-24.04-standard_24.04-2_amd64.tar.zst"
RALF_SSH_PUBKEY_FILE="/root/.ssh/ralf_ed25519.pub"
RUNTIME_DIR="/opt/ralf/runtime"

# Optional (needed for real apply hooks)
PROXMOX_API_TOKEN_ID=""
PROXMOX_API_TOKEN_SECRET=""

# Optional: per-service resource overrides (defaults shown)
# MINIO_CORES=2
# MINIO_MEM_MB=2048
# MINIO_DISK_GB=32
# POSTGRES_CORES=2
# POSTGRES_MEM_MB=2048
# POSTGRES_DISK_GB=32
# GITEA_CORES=2
# GITEA_MEM_MB=2048
# GITEA_DISK_GB=32
# SEMAPHORE_CORES=2
# SEMAPHORE_MEM_MB=2048
# SEMAPHORE_DISK_GB=32
# VAULTWARDEN_CORES=1
# VAULTWARDEN_MEM_MB=512
# VAULTWARDEN_DISK_GB=8
# PROMETHEUS_CORES=2
# PROMETHEUS_MEM_MB=2048
# PROMETHEUS_DISK_GB=32
# N8N_CORES=2
# N8N_MEM_MB=2048
# N8N_DISK_GB=16
# KI_CORES=4
# KI_MEM_MB=8192
# KI_DISK_GB=64
# MATRIX_CORES=2
# MATRIX_MEM_MB=2048
# MATRIX_DISK_GB=32

# Note: Per-service PostgreSQL credentials are auto-generated by the 020-postgresql hook
# and stored in $RUNTIME_DIR/state/postgresql-credentials.env (mode 600).
# Do NOT commit that file. It is excluded via .gitignore.

# DNS helper commands:
# bash bootstrap/dns-manifest.sh --config bootstrap/bootstrap.env
# bash bootstrap/dns-unbound-opnsense.sh --config bootstrap/bootstrap.env
# bash bootstrap/dns-verify.sh --config bootstrap/bootstrap.env
